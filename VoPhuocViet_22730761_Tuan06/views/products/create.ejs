<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">
                    <i class="fas fa-plus-circle"></i> Thêm Sản Phẩm Mới
                </h3>
            </div>
            <div class="card-body">
                <% if (error) { %>
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> <%= error %>
                </div>
                <% } %>

                <form action="/products/create" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="name" class="form-label">
                            <i class="fas fa-tag"></i> Tên sản phẩm <span class="text-danger">*</span>
                        </label>
                        <input type="text" class="form-control" id="name" name="name" 
                               placeholder="Nhập tên sản phẩm" required>
                    </div>

                    <div class="mb-3">
                        <label for="price" class="form-label">
                            <i class="fas fa-dollar-sign"></i> Giá (VNĐ) <span class="text-danger">*</span>
                        </label>
                        <input type="number" class="form-control" id="price" name="price" 
                               placeholder="Nhập giá sản phẩm" min="0" step="1000" required>
                    </div>

                    <div class="mb-3">
                        <label for="quantity" class="form-label">
                            <i class="fas fa-boxes"></i> Số lượng <span class="text-danger">*</span>
                        </label>
                        <input type="number" class="form-control" id="quantity" name="quantity" 
                               placeholder="Nhập số lượng" min="0" required>
                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-label">
                            <i class="fas fa-image"></i> Hình ảnh sản phẩm
                        </label>
                        <input type="file" class="form-control" id="image" name="image" 
                               accept="image/*" onchange="previewImage(event)">
                        <small class="text-muted">Định dạng: JPG, JPEG, PNG, GIF, WEBP (Tối đa 5MB)</small>
                        <div id="imagePreview" class="mt-3"></div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a href="/products" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Thêm Sản Phẩm
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function previewImage(event) {
    const preview = document.getElementById('imagePreview');
    const file = event.target.files[0];
    
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.innerHTML = `
                <img src="${e.target.result}" class="img-thumbnail" 
                     style="max-height: 200px;" alt="Preview">
            `;
        };
        reader.readAsDataURL(file);
    } else {
        preview.innerHTML = '';
    }
}
</script>
